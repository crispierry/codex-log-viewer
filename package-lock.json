{
  "name": "codex-log-viewer",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "codex-log-viewer",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*",
        "apps/cli",
        "apps/server"
      ],
      "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^5.9.0"
      },
      "engines": {
        "node": ">=24"
      }
    },
    "apps/cli": {
      "name": "@codex-log-viewer/cli",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@codex-log-viewer/analytics": "0.1.0",
        "@codex-log-viewer/parser": "0.1.0"
      },
      "bin": {
        "codex-log-viewer": "dist/index.js"
      }
    },
    "apps/server": {
      "name": "@codex-log-viewer/server",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@codex-log-viewer/analytics": "0.1.0",
        "@codex-log-viewer/parser": "0.1.0"
      }
    },
    "node_modules/@codex-log-viewer/analytics": {
      "resolved": "packages/analytics",
      "link": true
    },
    "node_modules/@codex-log-viewer/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@codex-log-viewer/parser": {
      "resolved": "packages/parser",
      "link": true
    },
    "node_modules/@codex-log-viewer/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@types/node": {
      "version": "24.12.2",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "undici-types": "~7.16.0"
      }
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "node_modules/undici-types": {
      "version": "7.16.0",
      "dev": true,
      "license": "MIT"
    },
    "packages/analytics": {
      "name": "@codex-log-viewer/analytics",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@codex-log-viewer/parser": "0.1.0"
      }
    },
    "packages/parser": {
      "name": "@codex-log-viewer/parser",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
